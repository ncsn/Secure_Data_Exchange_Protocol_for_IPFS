{
  "name": "ipfs-desktop-privacy",
  "version": "1.0.0",
  "description": "IPFS Desktop with Triple Hashing & Enhanced Privacy Protocol",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "controller": "node src/controller/controller.cjs"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@libp2p/crypto": "^5.1.17",
    "@libp2p/identify": "^4.1.2",
    "@libp2p/kad-dht": "^16.2.2",
    "@libp2p/mplex": "^12.0.18",
    "@libp2p/noise": "^1.0.1",
    "@libp2p/tcp": "^11.0.17",
    "@multiformats/multiaddr": "^12.0.0",
    "it-pipe": "^3.0.0",
    "kubo-rpc-client": "^6.1.0",
    "libp2p": "^3.2.2",
    "multiformats": "^13.0.0",
    "uint8arrays": "^5.0.0"
  },
  "build": {
    "appId": "com.ipfs.privacy.desktop",
    "productName": "IPFS Privacy Desktop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
